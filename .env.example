# Amazon Bedrock configuration
# Required: full Bedrock model identifier (no default is assumed by the app)
# Examples:
#   us.anthropic.claude-sonnet-4-6          (cross-region inference profile)
#   us.anthropic.claude-3-5-sonnet-20241022-v2:0
#   anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MODEL_ID=

# AWS region that hosts your Bedrock model access
AWS_REGION=us-east-1

# AWS credentials. Leave blank to use the default credential chain
# (env vars set elsewhere, ~/.aws/credentials, IAM role, SSO, etc.).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Entry-point mode
# cli      — interactive terminal (default)
# mcp      — MCP server over stdio (for Claude Desktop / Cursor)
# mcp-http — MCP server over HTTP on MCP_PORT
APP_MODE=cli
MCP_PORT=8000

# Optional tuning
BEDROCK_MAX_TOKENS=1500
BEDROCK_TEMPERATURE=0.2
HTTP_TIMEOUT_SECONDS=15
MIN_WEBSITE_TEXT_CHARS=400
